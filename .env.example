# AI 프로바이더 설정 ("openai" | "anthropic")
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-nano

# Anthropic (해커톤 당일 전환)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# 외부 데이터 (해커톤 당일 설정)
NEWS_DATA_PATH=./data/news.json

# 국회 오픈API (https://open.assembly.go.kr)
ASSEMBLY_API_KEY=

# 공공데이터포털 (https://www.data.go.kr)
# - 보조금24 공공서비스 정보 API
# - 서민금융상품 정보 API
# - 중소벤처24 공고정보 API
DATA_GO_KR_API_KEY=

# 데이터 소스 ("mock" | "db")
# mock: JSON 목업 데이터 / db: SQLite 운영 DB
DATA_SOURCE=mock

# 뉴스 목록 페이지당 표시 건수
NEWS_PAGE_SIZE=20

# 앱 설정
NEXT_PUBLIC_APP_NAME=이르미 민생위기 조기경보 레이더
NEXT_PUBLIC_APP_DESCRIPTION=뉴스 기반 사회경제 리스크 조기 감지 및 대응 지원
